console.log("A"); // 1. Synchronous

setTimeout(() => {
    console.log("B"); // 5. Macrotask (Timer phase)
}, 0);

new Promise((resolve, reject) => {
    console.log("C"); // 2. Synchronous (Runs IMMEDIATELY inside the constructor)
    resolve();
});

setImmediate(() => {
    console.log("D"); // 6. Macrotask (Check phase)
});

process.nextTick(() => {
    console.log("E"); // 3. Microtask (High-priority nextTick queue)
});

console.log("F"); // 4. Synchronous


// A,C, F E, B,D  

Promise.resolve().then(() => console.log('Promise 1'));
process.nextTick(() => {
  console.log('NextTick 1');
  process.nextTick(() => console.log('NextTick 2'));
});
Promise.resolve().then(() => console.log('Promise 2'));

//Promise 1, Promise 2, NextTick 1, NextTick 2


console.log('1. Synchronous');

setImmediate(() => {
  console.log('4. setImmediate (Macrotask)');
});

process.nextTick(() => {
  console.log('2. process.nextTick (Microtask)');
});

Promise.resolve().then(() => {
  console.log('3. Promise (Microtask)');
});

/*
1. Synchronous
2. process.nextTick (Microtask)
3. Promise (Microtask)
4. setImmediate (Macrotask)
*/

setImmediate(() => {
  console.log('Immediate 1');
  process.nextTick(() => console.log('Tick inside Immediate'));
});

setImmediate(() => {
  console.log('Immediate 2');
});


// 'Immediate 1', 'Tick inside Immediate', 'Immediate 2' 




